#!/usr/bin/env bash

# bin/setup - Installs dependencies, compiles the code, and runs tests.
#
# This script should be run from the parking_lot directory.
# It will:
#   1. Install npm dependencies
#   2. Compile TypeScript to JavaScript
#   3. Run the test suite
#
# Exit codes:
#   0 - All steps successful
#   1 - One or more steps failed

set -e  # Exit on any error

# Determine script directory to find project root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

cd "$PROJECT_ROOT"

echo "=================================="
echo "  Parking Lot System - Setup"
echo "=================================="
echo ""

# Step 1: Install dependencies
echo "📦 Installing dependencies..."
npm install --silent
echo "✓ Dependencies installed"
echo ""

# Step 2: Compile TypeScript
echo "🔨 Compiling TypeScript..."
npm run build --silent
echo "✓ Compilation successful"
echo ""

# Step 3: Run tests
echo "🧪 Running tests..."
npm test
echo ""

echo "=================================="
echo "  Setup complete!"
echo "=================================="
echo ""
echo "You can now run the program:"
echo "  bin/parking_lot          # Interactive mode"
echo "  bin/parking_lot <file>   # File input mode"
echo ""
